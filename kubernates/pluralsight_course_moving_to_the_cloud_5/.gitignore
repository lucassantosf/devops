# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files
.terraform.lock.hcl

# Ignore plan output files
*.tfplan

# Ignore .idea directory for JetBrains IDEs
.idea/

# Ignore .vscode directory for VS Code
.vscode/

# Ignore Mac system files
.DS_Store

# Ignore Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# Ignore environment files
.env
.terraform.lock.hcl

# Ignore private key files
*.pem

# Ignore log files
*.log

# Ignore any .auto.tfvars files
*.auto.tfvars

# Ignore any .terraform-version files
.terraform-version

# Ignore any .terraform-docs.yml files
.terraform-docs.yml